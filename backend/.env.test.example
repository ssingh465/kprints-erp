# =====================================================================
# KPrints ERP — TEST environment template
# ---------------------------------------------------------------------
# Copy this file to backend/.env.test (gitignored) before running:
#   npm run test:reset
#   npm run test:e2e
#
# CRITICAL SAFETY RULES — read before populating values:
#   1. DATABASE_URL MUST point at a dedicated Supabase TEST project,
#      never the production project. The test-env guard in
#      backend/src/test/test-env-guard.ts will refuse to run if:
#        - TEST_ENV is not set to "true"  (defence in depth), AND
#        - DATABASE_URL hostname does not contain the substring "test"
#          OR is not explicitly allow-listed via TEST_DB_HOST_ALLOWLIST.
#   2. SUPABASE_* keys MUST belong to the same TEST project as
#      DATABASE_URL — never mix production keys with a TEST DB.
#   3. This file is read by tsx-run scripts (test-reset, seed-qa-users)
#      and by Playwright's globalSetup. NODE_ENV stays "development"
#      because validateConfig() enforces extra checks under "production".
# =====================================================================

# --- Hard safety switch (required, must equal "true") ---------------
TEST_ENV=true

# --- Supabase TEST project connection -------------------------------
# Format: postgresql://postgres:<PASSWORD>@db.<TEST-PROJECT-REF>.supabase.co:5432/postgres
# The hostname MUST contain "test" (e.g. db.kprints-test.supabase.co)
# OR you must add the hostname to TEST_DB_HOST_ALLOWLIST below.
DATABASE_URL="postgresql://postgres:[YOUR-TEST-PASSWORD]@db.[YOUR-TEST-PROJECT-REF].supabase.co:5432/postgres"

# Optional: comma-separated hostname allow-list that bypasses the
# "host must contain 'test'" check. Use for local Postgres instances
# such as "localhost", "127.0.0.1", "host.docker.internal", or a
# self-hosted Supabase staging box. NEVER add a production hostname.
TEST_DB_HOST_ALLOWLIST="localhost,127.0.0.1"

# --- Supabase TEST project keys -------------------------------------
SUPABASE_URL="https://[YOUR-TEST-PROJECT-REF].supabase.co"
SUPABASE_ANON_KEY="your-test-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-test-supabase-service-role-key"

# --- Local API / frontend pointing at TEST backend ------------------
FRONTEND_URL="http://localhost:4200"
CORS_ORIGIN="http://localhost:4200"
PORT=8000
NODE_ENV=development

# --- QA persona credentials (consumed by seed-qa-users + Playwright)
# Document them here so a single `backend/.env.test` file feeds both
# DB reset and Playwright fixtures. The seeder will refuse to create
# accounts if any value is blank or obviously a placeholder.
QA_USER_DOMAIN="example.com"
QA_USER_PASSWORD="ChangeMe!QaTest123"

# --- Playwright base URLs (consumed by e2e/global-setup.ts) ---------
E2E_BASE_URL="http://localhost:4200"
E2E_API_BASE_URL="http://localhost:8000/api"
