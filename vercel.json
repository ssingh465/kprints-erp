{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "npm install --prefix backend && npm install --prefix frontend --include=dev",
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "frontend/dist/kprints-erp/browser",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/index.ts": {
      "maxDuration": 30,
      "includeFiles": "backend/node_modules/.prisma/**"
    }
  }
}
